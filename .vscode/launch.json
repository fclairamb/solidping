{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Package",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/back"
        },
        {
            "name": "Launch with PostgreSQL (localhost:55432)",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/back",
            "args": ["serve"],
            "env": {
                "SP_DB_TYPE": "postgres",
                "SP_DB_URL": "postgres://soliduser:solidpass@localhost:55432/solidping?sslmode=disable"
            }
        }
    ]
}